# CartPath — Environment Variables for Docker Compose
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────

# Mapbox access token (for geocoding + map tiles)
# Get one free at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=

# JWT signing secret (any random string, 32+ chars)
# Generate with: openssl rand -hex 32
CARTPATH_JWT_SECRET=change-me-to-a-random-string

# ── Client Build ─────────────────────────────────────────────────────

# Mapbox token for the frontend (defaults to MAPBOX_ACCESS_TOKEN above)
# VITE_MAPBOX_TOKEN=

# Plausible analytics domain (leave empty to disable)
# VITE_PLAUSIBLE_DOMAIN=cartpath.app

# ── Production ───────────────────────────────────────────────────────

# Set to "production" on your real server (enables secure cookies, HTTPS)
# CARTPATH_ENV=production

# CORS origins — comma-separated list of allowed frontend origins
# CARTPATH_CORS_ORIGINS=https://cartpath.app,https://www.cartpath.app

# ── Email (Optional) ────────────────────────────────────────────────

# SMTP for sending verification emails (logs to console if not set)
# CARTPATH_SMTP_HOST=smtp.gmail.com
# CARTPATH_SMTP_PORT=587
# CARTPATH_SMTP_USER=
# CARTPATH_SMTP_PASSWORD=
# CARTPATH_FROM_EMAIL=noreply@cartpath.app

# ── Monitoring (Optional) ───────────────────────────────────────────

# Webhook URL for data staleness alerts (Slack/Discord incoming webhook)
# CARTPATH_ALERT_WEBHOOK=https://hooks.slack.com/services/...

# Health check interval in seconds (default: 21600 = 6 hours)
# CARTPATH_HEALTH_CHECK_INTERVAL=21600
