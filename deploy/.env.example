# CartPath — Environment Variables for Docker Compose
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Required: JWT signing secret (any random string, 32+ chars)
CARTPATH_JWT_SECRET=change-me-to-a-random-string

# Required: Mapbox access token (for geocoding and map tiles)
MAPBOX_ACCESS_TOKEN=

# Optional: Set to "production" on your real server (enables secure cookies)
# CARTPATH_ENV=production

# Optional: SMTP for sending verification emails (logs to console if not set)
# CARTPATH_SMTP_HOST=smtp.gmail.com
# CARTPATH_SMTP_PORT=587
# CARTPATH_SMTP_USER=
# CARTPATH_SMTP_PASSWORD=
# CARTPATH_FROM_EMAIL=noreply@cartpath.app
